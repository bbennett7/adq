# Neon PostgreSQL connection string
# Get this from: https://console.neon.tech → your project → Connection Details
# Use the "pooled" connection string for serverless/edge functions
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Shared secret used to authenticate on-demand cache revalidation requests from the admin tool
# Generate with: openssl rand -hex 32
REVALIDATION_SECRET=your-secret-here

# Pino log level — trace | debug | info | warn | error | fatal | silent (default: info)
LOG_LEVEL=info
